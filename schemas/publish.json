{
  "type": "object",
  "properties": {
    "blog": { "type": "string", "description": "블로그 식별자(예: pak2251). 생략 시 변수 tistory/blog 사용" },
    "title": { "type": "string", "description": "글 제목" },
    "contentMarkdown": { "type": "string", "description": "본문 마크다운(HTML로 변환되어 전송)" },
    "category": { "type": "integer", "description": "카테고리 ID(생략=0=없음). 이름→ID는 category/simple.json 참고" },
    "tag": { "type": "array", "items": { "type": "string" }, "description": "태그 목록" },
    "visibility": { "type": "string", "enum": ["public", "protected", "private"], "description": "공개 범위(기본 private)" },
    "slug": { "type": "string", "description": "글 주소(slogan). 생략 시 제목 사용" }
  },
  "required": ["title", "contentMarkdown"]
}
